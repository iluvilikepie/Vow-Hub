local function StableFolderBreak(charFolder)
    for i = 1, 2 do
        for _, part in pairs(charFolder:GetChildren()) do
            if part:IsA("BasePart") then
                part.Anchored = true
                part.AssemblyLinearVelocity = Vector3.zero
                part.AssemblyAngularVelocity = Vector3.zero
            end
        end
        RS.CharacterEvents.Struggle:FireServer()
        task.wait(0.05)
        for _, part in pairs(charFolder:GetChildren()) do
            if part:IsA("BasePart") then
                part.Anchored = false
                if part.Name:find("Leg") or part.Name:find("Arm") then
                    part.CanCollide = false
                end
                part.AssemblyLinearVelocity = Vector3.zero
                part.AssemblyAngularVelocity = Vector3.zero
            end
        end
    end
    task.wait(0.4)
    for _, part in pairs(charFolder:GetChildren()) do
        if part:IsA("BasePart") and (part.Name:find("Leg") or part.Name:find("Arm")) then
            part.CanCollide = true
        end
    end
end

