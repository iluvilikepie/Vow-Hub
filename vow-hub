-- 1. THE PURGE LOGIC
local function PurgeRagdoll()
    local char = LP.Character
    if not char then return end
    
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        -- Target: image_f470a2 (The Ragdolled object inside Humanoid)
        local rVal = hum:FindFirstChild("Ragdolled")
        if rVal then rVal:Destroy() end
        
        -- Prevent "Dying" from broken joints
        hum.RequiresNeck = false
        hum.BreakJointsOnDeath = false
        if hum.Health > 0 and hum.Health < 1 then hum.Health = 100 end
        
        -- State Enforcement
        if hum:GetState() == Enum.HumanoidStateType.Ragdoll or hum:GetState() == Enum.HumanoidStateType.FallingDown then
            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
        end
    end

    -- Target: image_f660bf (The Player Values)
    -- We force "IsHeld" to false so the game thinks you aren't grabbed
    local isHeld = LP:FindFirstChild("IsHeld")
    if isHeld and isHeld.Value == true then isHeld.Value = false end

    -- Target: image_f663cb (The Character Body Parts)
    for _, v in pairs(char:GetDescendants()) do
        -- Destroy the specific "Ragdoll" parts and constraints from your screenshot
        if v:IsA("Constraint") or v.Name:find("Ragdoll") or v.Name:find("BallSocket") then
            v:Destroy()
        end
        
        -- Destroy the Hitboxes and Extra Parts the game attaches
        if v.Name == "RagdollTouchedHitbox" or v.Name == "RagdollLimbPart" or v.Name == "FirePlayerPart" then
            v:Destroy()
        end

        -- Target: Joint Enforcement (Keep your Motor6Ds alive)
        if v:IsA("Motor6D") then
            v.Enabled = true
        end
    end
end

