-- M6D Watcher: Keeps joints enabled so you don't fall apart during a grab
local function FH_SetupM6DConns()
    for _, c in pairs(FH_M6DConns) do pcall(function() c:Disconnect() end) end
    FH_M6DConns = {}

    local char = game.Players.LocalPlayer.Character
    local torso = char and char:FindFirstChild("Torso")
    if not torso then return end

    for _, i in pairs(torso:GetChildren()) do
        if i:IsA("Motor6D") then
            local conn = i:GetPropertyChangedSignal("Enabled"):Connect(function()
                if AntiGbTG then i.Enabled = true end
            end)
            table.insert(FH_M6DConns, conn)
        end
    end
end

-- Property Watcher: Blocks the game from forcing you to Sit or Ragdoll
local function FH_SetupPchanged()
    local hum = FH_Hum()
    local hrp = FH_HRP()
    if not hum or not hrp then return end

    FH_SitConn = hum:GetPropertyChangedSignal("Sit"):Connect(function()
        if not hum.SeatPart and AntiGbTG then
            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
            hum.Sit = false
        end
    end)

    FH_AutoRotConn = hum:GetPropertyChangedSignal("AutoRotate"):Connect(function()
        if not hum.AutoRotate and AntiGbTG then hum.AutoRotate = true end
    end)

    local ragdolled = hum:FindFirstChild("Ragdolled")
    if ragdolled then
        FH_RagdollConn = ragdolled:GetPropertyChangedSignal("Value"):Connect(function()
            if AntiGbTG then ragdolled.Value = false end
        end)
    end

    local animator = hum:FindFirstChildWhichIsA("Animator")
    if animator then
        FH_AnimConn = animator.AnimationPlayed:Connect(function(track)
            if track.Animation.AnimationId == "rbxassetid://7047322890" and AntiGbTG then
                track:Stop() -- Kills the grab animation
            end
        end)
    end
end

