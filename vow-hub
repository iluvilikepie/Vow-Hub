do
    local RS_L      = game:GetService("ReplicatedStorage")
    local RunSvc_L  = game:GetService("RunService")
    local Players_L = game:GetService("Players")
    local LP_L      = Players_L.LocalPlayer

    local SetNet_L    = RS_L.GrabEvents.SetNetworkOwner
    local DestroyLn_L = RS_L.GrabEvents.DestroyGrabLine
    local DestroyTy_L = RS_L.MenuToys.DestroyToy
    local SpawnTy_L   = RS_L.MenuToys.SpawnToyRemoteFunction

    local HOLD_OFFSET = Vector3.new(0, 20, 0)
    local lgkActive   = false
    local killActive  = false

    local function get_hrp()
        local c = LP_L.Character
        return c and c:FindFirstChild("HumanoidRootPart")
    end

    local function get_hum()
        local c = LP_L.Character
        return c and c:FindFirstChildOfClass("Humanoid")
    end

    local function get_inv()
        return workspace:FindFirstChild(LP_L.Name .. "SpawnedInToys")
    end

    local function sno_l(obj)
        SetNet_L:FireServer(obj, obj.CFrame)
    end

    local function stvel_l(part)
        pcall(function()
            part.AssemblyLinearVelocity  = Vector3.zero
            part.AssemblyAngularVelocity = Vector3.zero
            part.Velocity                = Vector3.zero
        end)
    end

    local function tp_l(obj1, obj2)
        local ping = 0
        pcall(function()
            ping = game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue()
        end)
        obj1.CFrame = CFrame.new(obj2.Position + obj2.Velocity * (ping / 1000) * 5)
    end

    local function gblob_l()
        local c   = LP_L.Character
        local hum = c and c:FindFirstChild("Humanoid")
        if hum and hum.SeatPart then
            if hum.SeatPart.Parent.Name == "CreatureBlobman" then
                return hum.SeatPart.Parent
            end
        end
    end

    local function spawntoy_l(toyName, cf)
        local inv = get_inv()
        if not inv then return nil end
        local result = nil
        local conn = inv.ChildAdded:Connect(function(c)
            if c.Name == toyName then result = c end
        end)
        task.spawn(function()
            SpawnTy_L:InvokeServer(toyName, cf, Vector3.new(0, 0, 0))
        end)
        local t0 = tick()
        repeat task.wait() until result or tick() - t0 > 2
        conn:Disconnect()
        return result
    end

    local function blobBring(tHRP, returnPos)
        local myHRP = get_hrp()
        local myHum = get_hum()
        local inv   = get_inv()
        if not myHRP or not myHum or not inv then return end
        local blob = gblob_l()
            or inv:FindFirstChild("CreatureBlobman")
            or spawntoy_l("CreatureBlobman", myHRP.CFrame * CFrame.new(5, 5, 20))
        if not blob then return end
        repeat task.wait() until blob:FindFirstChild("RightDetector") and blob:FindFirstChild("VehicleSeat")
        blob.Name = "cringe_bring"
        repeat task.wait() blob.VehicleSeat:Sit(myHum) until myHum.SeatPart == blob.VehicleSeat
        local CG = blob.BlobmanSeatAndOwnerScript.CreatureGrab
        local CD = blob.BlobmanSeatAndOwnerScript.CreatureRelease
        blob.HumanoidRootPart.CFrame = tHRP.CFrame
        task.wait(0.2)
        repeat
            task.wait()
            CG:FireServer(blob.RightDetector, tHRP, blob.RightDetector.RightWeld)
            CD:FireServer(blob.RightDetector.RightWeld)
        until isnetworkowner(tHRP)
        task.wait(0.2)
        tHRP.CFrame  = returnPos * CFrame.new(0, 20, 0)
        myHRP.CFrame = returnPos
        DestroyTy_L:FireServer(inv:FindFirstChild("cringe_bring"))
        task.wait(0.5)
    end

    local LoopsTab = Window:CreateTab("loop grabs", nil)
    LoopsTab:CreateSection("loop grabs")

    LoopsTab:CreateToggle({
        Name         = "loopgrab (kick)",
        CurrentValue = false,
        Flag         = "Loops_LGKick",
        Callback     = function(on)
