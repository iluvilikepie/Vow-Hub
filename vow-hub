-- [[ THE FAST SEARCH ]] --
function updateTargetSeat()
    local folderName = player.Name .. "SpawnedInToys"
    local toysFolder = workspace:FindFirstChild(folderName)
    if not toysFolder then return nil end

    local latestBlob = nil
    local children = toysFolder:GetChildren()
    
    -- Find the newest Blobman
    for i = #children, 1, -1 do
        local child = children[i]
        if child.Name == "CreatureBlobman" then
            latestBlob = child
            break
        end
    end

    if latestBlob then
        -- Cache the seat so we don't have to look for it again
        return latestBlob:FindFirstChildWhichIsA("VehicleSeat", true) or latestBlob:FindFirstChildWhichIsA("Seat", true)
    end
    return nil
end

-- [[ THE HIGH-SPEED ENGINE ]] --
function startTurboSit()
    blobConn = RunService.Heartbeat:Connect(function()
        if not enabled then return end

        local char = player.Character
        local humanoid = char and char:FindFirstChild("Humanoid")
        if not humanoid then return end

        -- If we don't have a seat, or the old one was deleted, find a new one
        if not activeSeat or not activeSeat.Parent then
            activeSeat = updateTargetSeat()
        end

        -- THE SPEED FIX: 
        -- If not sitting, we use the cached seat to sit INSTANTLY.
        if activeSeat and not humanoid.Sit then
            task.spawn(function()
                pcall(function()
                    activeSeat:Sit(humanoid)
                end)
            end)
        end
    end)
end

