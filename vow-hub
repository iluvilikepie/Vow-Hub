-- Helper function to find the absolute closest campfire (Map or Player-spawned)
local function getClosestCampfire(myPos)
    local closest = nil
    local shortestDist = math.huge
    
    -- Recursive search finds them in Workspace and all [User]SpawnedInToys folders
    for _, v in pairs(workspace:GetDescendants()) do
        if v.Name == "Campfire" or v.Name == "CampFire" then
            local pos
            if v:IsA("BasePart") then
                pos = v.Position
            elseif v:IsA("Model") then
                pos = v:GetPivot().Position
            end
            
            if pos then
                local dist = (myPos - pos).Magnitude
                if dist < shortestDist then
                    shortestDist = dist
                    closest = v
                end
            end
        end
    end
    return closest
end

