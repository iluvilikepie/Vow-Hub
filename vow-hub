                    if tChar.Parent ~= workspace then
                        task.spawn(function() blobBring(tHRP, pos) end)
                        continue
                    end
                    for _ = 1, 4 do
                        DestroyLn_L:FireServer(tHRP)
                        RunSvc_L.RenderStepped:Wait()
                        SetNet_L:FireServer(tHRP, tHRP.CFrame)
                    end
                    if (tHRP.Position - myHRP.Position).Magnitude >= 29 and tChar.Parent == workspace then
                        task.wait(0.1)
                        tp_l(myHRP, tHRP)
                        task.wait(0.2)
                        sno_l(tHRP)
                        task.wait()
                        myHRP.CFrame = pos
                        task.wait(0.2)
                        for _, v in pairs(tChar:GetChildren()) do stvel_l(v) end
                    end
                    if tHRP.Position.Y < myHRP.Position.Y + 4 and tChar.Parent == workspace then
                        local t0 = tick()
                        repeat task.wait() sno_l(tHRP)
                        until (tChar.Head and tChar.Head:FindFirstChild("PartOwner")) or tick() - t0 > 2
                        myHRP.CFrame = pos
                        tHRP.CFrame  = myHRP.CFrame * CFrame.new(0, 20, 0)
                    end
                    if not kickbp or kickbp.Parent ~= tHRP then
                        if kickbp then pcall(function() kickbp:Destroy() end) end
                        kickbp          = Instance.new("BodyPosition")
                        kickbp.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                        kickbp.D        = 200
                        kickbp.Position = myHRP.Position + HOLD_OFFSET
                        kickbp.Parent   = tHRP
                    end
                    if not kickbg or kickbg.Parent ~= tHRP then
                        if kickbg then pcall(function() kickbg:Destroy() end) end
                        kickbg           = Instance.new("BodyGyro")
                        kickbg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
                        kickbg.D         = 100
                        kickbg.CFrame    = CFrame.new()
                        kickbg.Parent    = tHRP
                    end
                    task.spawn(function()
                        for _, v in pairs(tChar:GetChildren()) do stvel_l(v) end
                    end)
                    if kickbp and kickbp.Parent then
                        kickbp.Position = myHRP.Position + HOLD_OFFSET
                    end
                end
                if kickbp and kickbp.Parent then kickbp:Destroy() end
                if kickbg and kickbg.Parent then kickbg:Destroy() end
                lgkActive = false
            end)
        end,
    })

    LoopsTab:CreateToggle({
        Name         = "loopgrab (kill)",
        CurrentValue = false,
        Flag         = "Loops_Kill",
        Callback     = function(on)
            killActive = on
            if not on then return end
            task.spawn(function()
                while killActive do
                    RunSvc_L.RenderStepped:Wait()
                    local myHRP = get_hrp()
                    local myHum = get_hum()
                    if not myHRP or not myHum then continue end
                    local pos = myHRP.CFrame
                    local target = selectedKickPlayer
                    if not target or not target.Character then continue end
                    local tChar  = target.Character
                    local tHRP   = tChar:FindFirstChild("HumanoidRootPart")
                    local tHum   = tChar:FindFirstChildOfClass("Humanoid")
                    local tTorso = tChar:FindFirstChild("Torso")
                    if not tHRP or not tHum or not tTorso then continue end
                    if tChar.Parent ~= workspace then
                        task.spawn(function() blobBring(tHRP, pos) end)
